#!/usr/bin/env bash
#MISE description="Reset local dev database (drop + recreate + migrate)"
set -euo pipefail
cd "$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

export PGPASSWORD="${PGPASSWORD:-jetlag-dev}"
dropdb --if-exists -U jetlag -h localhost jetlag
createdb -U jetlag -h localhost jetlag
atlas migrate apply --url "${ATLAS_DATABASE_URL}" --env local
echo "Database reset and migrations applied."
