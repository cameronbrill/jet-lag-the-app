#!/usr/bin/env bash
#MISE description="Build client for a target platform"
#USAGE arg "<target>" help="Build target" {
#USAGE   choices "android" "desktop"
#USAGE }
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

case "${usage_target}" in
	android)
		export GRADLE_OPTS="-Xmx1536m"
		exec mise x -- ./gradlew :app:androidApp:assembleRelease --no-daemon --no-configuration-cache -Dorg.gradle.jvmargs="-Xmx1536m -XX:+UseSerialGC"
		;;
	desktop)
		exec mise x -- ./gradlew :app:desktopApp:packageDistributionForCurrentOS
		;;
	*)
		echo "Unknown build target: ${usage_target:-}" >&2
		exit 1
		;;
esac
