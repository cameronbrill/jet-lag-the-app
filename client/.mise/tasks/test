#!/usr/bin/env bash
#MISE description="Run KMP tests (--all to force allTests even without Xcode)"
#USAGE flag "--all" help="Force allTests regardless of platform"
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

if [[ "${usage_all:-false}" == "true" ]]; then
	exec mise x -- ./gradlew allTests
elif [[ "$(uname -s)" == Darwin ]] && xcrun xcodebuild -version >/dev/null 2>&1; then
	# Link smoke: ensures :app:shared iOS framework still compiles for simulator (see iosApp plan).
	mise x -- ./gradlew :app:shared:linkDebugFrameworkIosSimulatorArm64
	exec mise x -- ./gradlew allTests
else
	exec mise x -- ./gradlew desktopTest
fi
