{
  "json": {},
  "markdown": {},
  "toml": {},
  "exec": {
    "cwd": "${configDir}",
    "commands": [
      {
        "command": "bash backend/scripts/dprint-python-wrapper.sh {{file_path}}",
        "stdin": false,
        "exts": ["py"]
      },
      {
        "command": "bash scripts/dprint-kotlin-wrapper.sh {{file_path}}",
        "stdin": false,
        "exts": ["kt", "kts"]
      }
    ]
  },
  "excludes": [
    "**/node_modules",
    "**/*-lock.json",
    "**/uv.lock",
    "**/.venv",
    "**/build",
    "**/.gradle",
    "**/DerivedData"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.20.0.wasm",
    "https://plugins.dprint.dev/markdown-0.19.0.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
    "https://plugins.dprint.dev/exec-0.5.0.json@8d9972eee71fa1590e04873540421f3eda7674d0f1aae3d7c788615e7b7413d0",
    "https://plugins.dprint.dev/g-plane/malva-v0.14.2.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.23.2.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.5.1.wasm"
  ]
}
